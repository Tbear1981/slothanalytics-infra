# Host port for Jenkins UI (http://VPS_IP:8080)
JENKINS_HTTP_PORT=8080

# Inbound agents (optional; often unused if everything runs on controller)
JENKINS_AGENT_PORT=50000

# Job logs and cron schedules use this timezone
TZ=Europe/Copenhagen

# --- Jenkins CLI (scripts/download-cli.sh, scripts/jenkins-cli.sh) ---
# Copy to .env (gitignored): cp .env.example .env
# JENKINS_URL=http://127.0.0.1:8080
# JENKINS_AUTH=jenkins_username:api_token

# --- Create Pipeline job from SCM (scripts/create-data-grabber-job.sh) ---
# GIT_URL=https://github.com/YOU/datafordeler_regnskab.git
# GIT_CREDENTIALS_ID=          # Jenkins credential ID for git (private repos); leave empty if public
# GIT_BRANCH=*/main
# JENKINS_JOB_NAME=datafordeler-regnskab

# Optional: Secret file credential ID for import-data-grabber-env-credential.sh (must match Jenkinsfile)
# JENKINS_CREDENTIAL_ID_DATA_GRABBER_ENV=data-grabber-env
